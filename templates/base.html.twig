<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Sidus/AdminBundle Demo{% endblock %}</title>
    <link rel="icon" href="data:,">
    <link rel="stylesheet" href="{{ asset('styles/bulma.css') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.7.2/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <nav class="navbar is-light" role="navigation" aria-label="main navigation">
        <div class="container">
            <div class="navbar-brand">
                <a class="navbar-item has-text-weight-bold" href="{{ path('app_home') }}">
                    <span class="icon"><i class="fas fa-shield-halved"></i></span>
                    <span>&nbsp;Sidus/AdminBundle</span>
                </a>

                <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false"
                   data-target="main-navbar">
                    <span aria-hidden="true"></span>
                    <span aria-hidden="true"></span>
                    <span aria-hidden="true"></span>
                </a>
            </div>

            <div id="main-navbar" class="navbar-menu">
                <div class="navbar-start">
                    <a class="navbar-item" href="{{ path('app_home') }}">Home</a>
                    <a class="navbar-item" href="{{ admin_path('News', 'list') }}">
                        <span class="icon"><i class="fas fa-address-book"></i></span>
                        <span>&nbsp;News</span>
                    </a>
                </div>

                <div class="navbar-end">
                    <div class="navbar-item">
                        <a class="button is-dark" href="https://github.com/VincentChalnot/SidusAdminDemo">
                            <span class="icon"><i class="fab fa-github"></i></span>
                            <span>Fork me on GitHub</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <section class="section">
        <div class="container is-wide">
            {% block body %}
                {% block container %}{% endblock %}
            {% endblock %}
        </div>
    </section>

    <footer class="footer">
        <div class="container">
            <div class="content has-text-centered">
                <p>
                    <strong>Sidus/AdminBundle Demo</strong> &mdash; built with
                    <a href="https://symfony.com">Symfony</a>,
                    <a href="https://github.com/VincentChalnot/SidusAdminBundle">Sidus/AdminBundle</a> and
                    <a href="https://bulma.io">Bulma</a>.
                </p>
            </div>
        </div>
    </footer>

</body>
</html>
