{% extends 'base.html.twig' %}

{% block title %}Sidus/AdminBundle Demo{% endblock %}

{% block container %}
    <section class="hero is-primary is-medium">
        <div class="hero-body">
            <p class="title">Sidus/AdminBundle Demo</p>
            <p class="subtitle">
                Action-based admin management with built-in routing generation for Symfony.
            </p>
            <a class="button is-white is-outlined" href="{{ admin_path('News', 'list') }}">
                <span class="icon"><i class="fas fa-table-list"></i></span>
                <span>Browse the News datagrid example</span>
            </a>
        </div>
    </section>

    <div class="columns mt-5">
        <div class="column is-8">
            <h2 class="title is-4">What is this?</h2>
            <div class="content">
                <p>
                    This demo wires together three small, focused bundles to build a full CRUD admin
                    section from plain YAML configuration &mdash; no scaffolding, no generated
                    controllers:
                </p>
                <ul>
                    <li>
                        <a href="https://github.com/VincentChalnot/SidusAdminBundle">
                            <strong>Sidus/AdminBundle</strong>
                        </a> &mdash; declares admin sections (routes, actions, templates, forms) from
                        configuration.
                    </li>
                    <li>
                        <a href="https://github.com/VincentChalnot/SidusDataGridBundle">
                            <strong>Sidus/DataGridBundle</strong>
                        </a> &mdash; renders sortable, paginated, filterable listings.
                    </li>
                    <li>
                        <a href="https://github.com/VincentChalnot/SidusFilterBundle">
                            <strong>Sidus/FilterBundle</strong>
                        </a> &mdash; turns query parameters into Doctrine ORM filters.
                    </li>
                </ul>
                <p>
                    The <code>News</code> entity below is managed entirely through
                    <code>config/admin/News.yaml</code> and <code>config/datagrid/News.yaml</code>.
                </p>
            </div>
        </div>
        <div class="column is-4">
            <div class="box">
                <h3 class="title is-5">Try it</h3>
                <div class="content">
                    <ol>
                        <li>Open the <a href="{{ admin_path('News', 'list') }}">News datagrid</a>.</li>
                        <li>Sort columns, filter by author, category, date or status.</li>
                        <li>Create, edit, read and delete entries &mdash; all generated actions.</li>
                    </ol>
                </div>
                <a class="button is-primary is-fullwidth" href="{{ admin_path('News', 'create') }}">
                    <span class="icon"><i class="fas fa-plus"></i></span>
                    <span>Create a News item</span>
                </a>
            </div>
        </div>
    </div>
{% endblock %}
